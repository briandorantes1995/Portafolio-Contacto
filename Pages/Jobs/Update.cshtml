@page "{id:int}"
@model Portafolio.Pages.Jobs.Update
@using Portafolio.Models

<div class="container">

    <h1>Editar/Actualizar Proyecto</h1>

    <form method="post">

        <div class="form-group">
            <label asp-for="Input.Title">Nombre</label>
            <input asp-for="Input.Title" class="form-control" />
        </div>

        <div class="form-group">
            <label asp-for="Input.Budget">Presupuesto</label>
            <input asp-for="Input.Budget" type="number" class="form-control" />
        </div>

        <div class="form-group">
            <label asp-for="Input.Description">Detalle/Instrucciones</label>
            <textarea asp-for="Input.Description" class="form-control"></textarea>
        </div>
        
        <div class="form-group">
            <label asp-for="Input.Status">Estatus</label>
            <select asp-for="Input.Status"
                    asp-items="Html.GetEnumSelectList<Statuses>()"
                    class="form-control">
            </select>
        </div>
        
        <div class="form-group">
            <label asp-for="Input.SubStatus">SubEstatus</label>
            <select asp-for="Input.SubStatus"
                    asp-items="Html.GetEnumSelectList<SubStatuses>()"
                    class="form-control">
            </select>
        </div>
        
        <div class="form-group">
            <label asp-for="Input.StartDate">Fecha de Inicio</label>
            <input asp-for="Input.StartDate" type="date" class="form-control" />
        </div>
        
        
        <div class="form-group">
            <label asp-for="Input.EndDate">Fecha Estimada de Finalizacion</label>
            <input asp-for="Input.EndDate" type="date" class="form-control" />
        </div>
        
        <button type="submit" class="btn btn-primary">Guardar Cambios</button>
    </form>
</div>